{% extends 'student/_layouts/after-login.html.twig' %}
{% form_theme form 'student/_layouts/form-tailwind.html.twig' %}

{% block stylesheets %}
    {{ encore_entry_link_tags('admin_default') }}
{% endblock %}

{% block javascripts %}
    {{ encore_entry_script_tags('admin_default') }}
{% endblock %}
{% block title %}{% trans %}Składanie wniosku - krok 2{% endtrans %} | Help VIZJA{% endblock %}
{% block body %}
    <section class="space-y-8">
        <h1 id="page-title" class="wrap-break-word text-xl font-semibold md:text-2xl lg:text-3xl">
            {% trans %}Złóż wniosek{% endtrans %}
        </h1>

        {% set visibleStep = adaptationRequired ? 3 : 2 %}

        {% include 'student/application/_partials/stepper.html.twig' with {
            currentStep: visibleStep,
            adaptationRequired: adaptationRequired
        } %}

        {{ form_start(form, {'attr': { 'novalidate': 'novalidate' }}) }}

        <div class="space-y-8">
            <h2 class="flex items-center wrap-break-word font-medium text-md md:text-lg lg:text-xl">
                {% trans %}Krok{% endtrans %} {{ visibleStep }}. {% trans %}Uzupełnij formularz{% endtrans %}
            </h2>

            {# Podsumowanie błędów #}
            {% set hasFormErrors = (form_errors(form)|trim) is not empty %}
            {% set childErrors = [] %}

            {% for child in form %}
                {% if child is defined and child.vars is defined and child.vars.errors|length > 0 %}
                    {% set labelTxt = (child.vars.label is not empty) ? child.vars.label : (child.vars.name|capitalize) %}
                    {% set childErrors = childErrors|merge([{
                        id: child.vars.id,
                        label: labelTxt,
                        errors: child.vars.errors
                    }]) %}
                {% endif %}
            {% endfor %}

            {% if hasFormErrors or childErrors is not empty %}
                {% include '_partials/form-errors.html.twig' with { form: form, childErrors: childErrors } %}
            {% endif %}

            <div class="max-w-2xl w-full space-y-4">
                <div class="max-w-2xl w-full space-y-6">
                    {{ form_row(form.albumNumber) }}
                    {{ form_row(form.phone) }}
                    {{ form_row(form.studyMode) }}
                    {{ form_row(form.year) }}
{#                    {{ form_row(form.semester) }}#}
                    {{ form_row(form.faculty) }}
                </div>



            <div class="min-w-0">
                {% include 'student/application/_form/' ~ application.type.hiddenValue ~ '.html.twig' %}
            </div>
        </div>

        <div class="mt-10 flex flex-wrap gap-2">
            <a
                class="{{ buttonSecondary() }} {{ focusPrimaryWithPadding() }}"
                href="{{
                adaptationRequired
                ? path('student_choose_adaptation')
                : path('student_choose_application_type')
                }}"
            >
                {% trans %}Wróć do poprzedniego kroku{% endtrans %}
            </a>
            <button class="cursor-pointer {{ buttonPrimary() }} {{ focusPrimaryWithPadding() }}" type="submit">
                {% trans %}Przejdź dalej{% endtrans %}
            </button>
        </div>
        {{ form_end(form, { render_rest: false }) }}
    </section>
{% endblock %}
