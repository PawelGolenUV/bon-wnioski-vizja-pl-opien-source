<li class="flex items-center justify-between py-2">
    <span>{% trans %}Rodzaje adaptacji{% endtrans %}</span>

    <div class="font-medium">
        {% if application.adaptations|length > 0 %}
            <ul class="list-disc list-inside max-w-md space-y-1">
                {% for item in application.adaptations %}
                    {% if app.locale === 'pl' %}
                    <li>{{ item.value }}</li>
                    {% else %}
                        <li>{{ item.valueEnglish }}</li>
                        {% endif %}
                {% endfor %}
            </ul>
        {% else %}
            &mdash;
        {% endif %}
    </div>
</li>

<li class="py-2">
    <span class="block">{% trans %}Uzasadnienie{% endtrans %}</span>
    <span class="font-medium break-all whitespace-pre-line mt-1 block">
        {{ application.description }}
    </span>
</li>
