{% extends 'student/_layouts/before-login.html.twig' %}
{% block title %}{% trans %}Zaloguj się{% endtrans %} | Help VIZJA{% endblock %}

{% block stylesheets %}
    {{ encore_entry_link_tags('admin_default') }}
{% endblock %}


{% block javascripts %}
    {{ encore_entry_script_tags('admin_default') }}
{% endblock %}

{% block body %}

        <header>
            <nav aria-label="{% trans %}Nawigacja górna{% endtrans %}" class="bg-white dark:bg-zinc-900">
                <div class="flex flex-wrap items-center justify-end max-w-screen-2xl min-h-[100px] mx-auto px-4 py-2.5 md:px-4">
                    <div class="flex items-center md:space-x-2">
                        {% include 'admin/_components/change-theme.html.twig' %}
                        {% include 'student/_components/change-language.html.twig' %}
                    </div>
                </div>
            </nav>
        </header>

        <div class="flex flex-col items-center justify-center gap-6 md:flex-row">
            <figure class="max-w-lg">
                <img alt="{% trans %}Uniwersytet VIZJA{% endtrans %}"
                    class="block max-w-[320px] mx-auto my-4 dark:hidden"
                    src="{{ asset('images/logo/header/' ~ app.request.locale ~ '.png') }}">

                <img alt="{% trans %}Uniwersytet VIZJA{% endtrans %}"
                    class="hidden max-w-[320px] mx-auto my-4 dark:block"
                    src="{{ asset('images/logo/header/' ~ app.request.locale ~ '-transparent.png') }}">
            </figure>

            <figure class="max-w-lg">
                <img alt="{% trans %}logotyp Biura do spraw osób z niepełnosprawnościami{% endtrans %}"
                    class="block max-w-[320px] mx-auto my-4 dark:hidden"
                    src="{{ asset('images/logo/bon/' ~ app.request.locale ~ '.jpg') }}">
            </figure>
        </div>

        <section class="bg-zinc-50 dark:bg-zinc-900 mb-10">
            <div class="bg-white flex items-center justify-center px-4">
                <img alt="{% trans %}Logo Funduszy Europejskich{% endtrans %}"
                    class="block w-full max-w-[800px] h-auto py-5"
                    src="{{ asset('images/logo/unijne_logotypy.png') }}">
            </div>
            <div class="max-w-screen-2xl mx-auto px-4 py-8 space-y-8">
                <div class="bg-white mx-auto rounded-lg shadow-lg w-full max-w-200 dark:bg-zinc-800">
                    <div class="p-4 space-y-4 sm:p-8">
                        <h1 id="page-title" class="font-semibold text-lg md:text-2xl lg:text-3xl">
                            {% trans %}Panel pracowniczy{% endtrans %}
                        </h1>

                    </div>
                </div>

                <div class="items-start max-w-200 mx-auto space-y-10">
                    <div class="bg-white mx-auto order-2 rounded-lg shadow-lg w-full dark:bg-zinc-800 md:mt-0 lg:order-1 xl:p-0">
                        <div class="p-4 space-y-4 sm:p-8">
                            <h2 class="font-semibold text-lg md:text-2xl lg:text-3xl">
                                {% trans %}Zarejestrowani pracownicy uczelni{% endtrans %}
                            </h2>

                            <p class="font-semibold">
                                Jeśli posiadasz konto e-mail w domenie vizja.pl i twoje konto zostało założone w panelu
                            </p>

                            <div class="space-y-8">
                                <div>
                                    <a href="{{ path('admin_security_azure_login') }}" class="{{ buttonPrimary() }} {{ focusPrimaryWithPadding() }} text-center w-full">
                                        <div class="flex items-center justify-center">
                                            <svg class="flex h-6 mr-2 w-6"
                                                aria-hidden="true"
                                                xmlns="http://www.w3.org/2000/svg"
                                                viewBox="0 0 24 24">

                                                <path clip-rule="evenodd"
                                                    d="M3.005 12 3 6.408l6.8-.923v6.517H3.005ZM11 5.32 19.997 4v8H11V5.32ZM20.067 13l-.069 8-9.065-1.275L11 13h9.067ZM9.8 19.58l-6.795-.931V13H9.8v6.58Z"
                                                    fill="currentColor"
                                                    fill-rule="evenodd" />
                                            </svg>

                                            <span>
                                            {% trans %}Zaloguj się kontem Office 365{% endtrans %}
                                        </span>
                                        </div>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>


                </div>

            </div>

        </section>



    <footer class="bg-zinc-900 py-10 text-zinc-100" id="footer">
        <div class="mx-auto max-w-screen-2xl px-4 text-center min-w-0">
            <ul class="flex flex-col md:flex-row justify-center items-center min-w-0">
                <li class="min-w-0">
                    <a href="https://vizja.pl/kontakt/#biuro-rekrutacji" class="block px-4 py-2 rounded-lg underline hover:text-yellow-400 wrap-break-word {{ focusPrimary() }}">
                        {% trans %}Biuro Rekrutacji{% endtrans %}
                    </a>
                </li>
                <li class="min-w-0">
                    <a href="https://bon.vizja.pl/kontakt/" class="block px-4 py-2 rounded-lg underline hover:text-yellow-400 wrap-break-word {{ focusPrimary() }}">
                        {% trans %}Kontakt{% endtrans %}
                    </a>
                </li>
                <li class="min-w-0">
                    <a href="https://vizja.pl/kontakt/#social-media" class="block px-4 py-2 rounded-lg underline hover:text-yellow-400 wrap-break-word {{ focusPrimary() }}">
                        {% trans %}Social media{% endtrans %}
                    </a>
                </li>
                <li class="min-w-0">
                    <a href="https://vizja.pl/polityka-prywatnosci" class="block px-4 py-2 rounded-lg underline hover:text-yellow-400 wrap-break-word {{ focusPrimary() }}">
                        {% trans %}Polityka prywatności{% endtrans %}
                    </a>
                </li>
                <li class="min-w-0">
                    <a href="#" class="block px-4 py-2 rounded-lg underline hover:text-yellow-400 wrap-break-word {{ focusPrimary() }}">
                        {% trans %}Deklaracja dostępności{% endtrans %}
                    </a>
                </li>
            </ul>

            <div class="my-10"></div>

            <div class="flex flex-col justify-center items-center min-w-0">
                {% if app.request.locale == 'pl' %}
                    <img alt="{% trans %}Logo Uniwersytetu Vizja{% endtrans %}"
                        class="block w-full max-w-[260px] h-auto mb-10"
                        src="{{ asset('images/logo/uv/logo_pl_PL_poziom_kontra.png') }}">
                {% elseif app.request.locale == 'en' %}
                    <img alt="{% trans %}Logo Uniwersytetu Vizja{% endtrans %}"
                        class="block w-full max-w-[260px] h-auto mb-10"
                        src="{{ asset('images/logo/uv/logo_en_US_poziom_kontra.png') }}">
                {% endif %}

            </div>

            <div class="flex flex-col justify-center items-center gap-y-2 text-sm min-w-0">
                <div class="wrap-break-word">
                    {% trans %}ul. Okopowa 59{% endtrans %}
                </div>
                <div class="wrap-break-word">
                    01-043, {% trans %}Warszawa{% endtrans %}
                </div>
                <div class="wrap-break-word">
                    {% trans %}piętro{% endtrans %} II, {% trans %}pokój{% endtrans %} 233
                </div>
                <div class="mt-10 mb-5 px-4 w-full min-w-0">
                    <div class="max-w-screen-2xl mx-auto text-left min-w-0">
                        <div class="max-w-none wrap-break-word min-w-0">
                            {% trans %}Program do zarządzania usługami Biura ds. Osób z Niepełnosprawnościami (BON) został opracowany przez Uniwersytet VIZJA w ramach realizacji projektu{% endtrans %}
                            <a class="underline wrap-break-word" rel="noopener noreferrer"
                                href="https://vizja.pl/projekty-europejskie/vizja-home-uczelnia-dla-wszystkich/">
                                {% trans %}Vizja Home – Uczelnia dla wszystkich{% endtrans %}
                            </a>
                            {% trans %}w ramach programu Fundusze Europejskie dla Rozwoju Społecznego 2021-2027 współfinansowanego ze środków Europejskiego Funduszu Społecznego Plus i objęty jest w całości licencją{% endtrans %}
                            <a class="underline wrap-break-word" rel="noopener noreferrer"
                                href="https://creativecommons.org/licenses/by/4.0/legalcode.pl">
                                {% trans %}Creative Commons Uznanie autorstwa CC BY 4.0{% endtrans %}
                            </a>.
                            <p class="mt-2">
                                <a class="underline wrap-break-word" rel="noopener noreferrer"
                                    href="{{ url('admin_license_index') }}">
                                    {% trans %}Więcej o Help VIZJA i licencji{% endtrans %}
                                </a>
                            </p>

                            <div class="mt-7">
                                <div class="flex flex-wrap items-center gap-2" role="img" aria-label="{% trans %}Logo licencji Creative Commons – Uznanie autorstwa{% endtrans %}">
                                    <svg class="fill-white w-8 h-8 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640">
                                        <path
                                            d="M317.8 278.9L284.6 296.2C275.2 276.6 259.4 276.3 257.1 276.3C235 276.3 223.9 290.9 223.9 320.1C223.9 343.7 233.1 363.9 257.1 363.9C271.6 363.9 281.7 356.8 287.7 342.6L318.3 358.1C312.1 369.6 292.6 397.1 253.2 397.1C230.6 397.1 179.2 386.8 179.2 320.1C179.2 261.4 222.2 243 251.8 243C282.5 243 304.5 254.9 317.8 278.9zM460.8 278.9L428 296.2C418.5 276.4 402.3 276.3 400.1 276.3C378 276.3 366.9 290.9 366.9 320.1C366.9 343.6 376.1 363.9 400.1 363.9C414.5 363.9 424.7 356.8 430.6 342.6L461.6 358.1C459.5 361.9 440.2 397.1 396.5 397.1C373.8 397.1 322.5 387.2 322.5 320.1C322.5 261.4 365.5 243 395.1 243C425.8 243 447.7 254.9 460.7 278.9zM319.6 72C176.7 72 72 187.1 72 320.1C72 458.5 185.6 568.1 319.6 568.1C449.5 568.1 568 467.2 568 320.1C568 182.2 461.4 72 319.6 72zM320.5 522.8C208 522.8 116.8 429.8 116.8 320C116.8 214.6 202.2 116.7 320.5 116.7C433 116.7 523.3 206.2 523.3 320C523.3 441.7 423.6 522.8 320.5 522.8z" />
                                    </svg>
                                    <svg class="fill-white w-8 h-8 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640">
                                        <path
                                            d="M386.9 258.4L386.9 359.8L358.6 359.8L358.6 480.3L281.5 480.3L281.5 359.9L253.2 359.9L253.2 258.4C253.2 254 254.8 250.2 257.8 247.1C260.9 244 264.7 242.4 269.1 242.4L371 242.4C375.1 242.4 378.8 244 382.1 247.1C385.2 250.3 386.9 254 386.9 258.4zM354.4 193.9C354.6 213 339.4 228.6 320.3 228.8C301.2 229 285.6 213.8 285.4 194.7C285.2 175.6 300.4 160 319.5 159.8C338.6 159.6 354.2 174.8 354.4 193.9zM319.6 72C461.4 72 568 182.1 568 320C568 467.1 449.5 568 319.6 568C185.6 568 72 458.5 72 320C72 187.1 176.7 72 319.6 72zM320.4 116.7C202.2 116.7 116.7 214.6 116.7 320C116.7 429.8 207.9 522.8 320.4 522.8C423.6 522.8 523.2 441.7 523.2 320C523.3 206.2 433 116.7 320.4 116.7z" />
                                    </svg>
                                </div>

                                <div class="mt-2 wrap-break-word">
                                    {% trans %}Ikony Creative Commons (CC){% endtrans %}:
                                    <a
                                        class="underline wrap-break-word"
                                        rel="noopener noreferrer"
                                        target="_blank"
                                        href="https://fontawesome.com/"
                                    >
                                        Font Awesome
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </footer>
{% endblock %}
