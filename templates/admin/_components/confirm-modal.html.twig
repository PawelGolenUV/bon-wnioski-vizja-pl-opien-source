{# WYMAGANE ZMIENNE:
    modalId       - unikalne ID modala
    formId        - ID formularza, który ma być submitowany
    title         - tytuł modala
    message       - główna treść
    warningText   - tekst ostrzeżenia (opcjonalnie)
    confirmLabel  - tekst na przycisku potwierdzenia
    cancelLabel   - tekst na przycisku anulowania
#}

<div
    id="{{ modalId }}"
    tabindex="-1"
    role="dialog"
    aria-modal="true"
    aria-labelledby="{{ modalId }}-title"
    aria-hidden="true"
    class="hidden overflow-y-auto overflow-x-hidden fixed top-0 right-0 left-0 z-50 justify-center items-center w-full md:inset-0 h-modal md:h-full"
>
    <div class="relative p-4 w-full max-w-md h-full md:h-auto">
        <div class="relative p-4 text-center bg-white rounded-lg shadow dark:bg-zinc-800 sm:p-5">
            <button type="button"
                class="text-zinc-400 absolute top-2.5 right-2.5 bg-transparent hover:bg-zinc-200 hover:text-zinc-900 rounded-lg text-sm p-1.5 ml-auto inline-flex items-center dark:hover:bg-zinc-600 dark:hover:text-white {{ focusPrimary() }}"
                data-modal-toggle="{{ modalId }}">
                <svg aria-hidden="true" class="w-5 h-5 text-black dark:text-white" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd"
                        d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z"
                        clip-rule="evenodd"></path>
                </svg>
                <span class="sr-only">{% trans %}Zamknij okno{% endtrans %}</span>
            </button>

            <h2
                id="{{ modalId }}-title"
                tabindex="-1"
                class="mb-2 text-lg font-semibold text-zinc-900 dark:text-white"
            >
                {{ title|raw }}
            </h2>

            {% if message is defined and message %}
                <p class="mb-4 text-base">
                    {{ message|raw }}
                </p>
            {% endif %}

            {% if warningText is defined and warningText %}
                <div class="p-4 mb-4 text-sm text-left text-orange-700 bg-orange-100 rounded-lg sm:mb-5 dark:bg-zinc-700 dark:text-orange-300"
                    role="note">
                    <div class="items-center mb-1">
                        <svg class="inline flex-shrink-0 mr-1 w-4 h-4" aria-hidden="true" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd"
                                d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z"
                                clip-rule="evenodd"></path>
                        </svg>
                        <span class="font-semibold leading-none">Uwaga</span>
                    </div>
                    <p>{{ warningText|raw }}</p>
                </div>
            {% endif %}

            <div class="flex justify-center items-center space-x-4">
                <button
                    data-modal-toggle="{{ modalId }}"
                    type="button"
                    class="{{ buttonPrimary() }} {{ focusPrimary() }}">
                    {{ cancelLabel|default('') }}
                </button>

                <button
                    type="button"
                    onclick="document.getElementById('{{ formId }}').submit();"
                    class="{{ buttonDelete() }} {{ focusPrimary() }}">
                    {{ confirmLabel|default('') }}
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const modal = document.getElementById('{{ modalId }}');

        if (!modal) {
            return;
        }

        let previouslyFocusedElement = null;

        const getFocusableElements = () => {
            return modal.querySelectorAll(
                'a[href], button:not([disabled]), textarea, input, select, [tabindex]:not([tabindex="-1"])'
            );
        };

        const trapFocus = (event) => {
            if (event.key !== 'Tab') {
                return;
            }

            const focusableElements = getFocusableElements();

            if (!focusableElements.length) {
                return;
            }

            const firstElement = focusableElements[0];
            const lastElement = focusableElements[focusableElements.length - 1];

            if (event.shiftKey) {
                if (document.activeElement === firstElement) {
                    event.preventDefault();
                    lastElement.focus();
                }
            } else {
                if (document.activeElement === lastElement) {
                    event.preventDefault();
                    firstElement.focus();
                }
            }
        };

        const observer = new MutationObserver(() => {
            const isOpen = !modal.classList.contains('hidden');

            if (isOpen) {
                if (!previouslyFocusedElement) {
                    previouslyFocusedElement = document.activeElement;
                }

                const focusableElements = getFocusableElements();

                const title = document.getElementById('{{ modalId }}-title');

                if (
                    title &&
                    !modal.contains(document.activeElement)
                ) {
                    title.focus();
                }

                document.addEventListener('keydown', trapFocus);
            } else {
                document.removeEventListener('keydown', trapFocus);

                if (previouslyFocusedElement) {
                    previouslyFocusedElement.focus();
                    previouslyFocusedElement = null;
                }
            }
        });

        observer.observe(modal, {
            attributes: true,
            attributeFilter: ['class']
        });
    });
</script>
