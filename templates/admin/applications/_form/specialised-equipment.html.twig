<p id="form_help" class="sr-only">
    {% trans %}Formularz zgłoszeniowy. Pola wymagane oznaczono gwiazdką. Użyj klawisza Tab, aby przechodzić między polami.{% endtrans %}
</p>

{# Podsumowanie błędów #}
{% set hasFormErrors = (form_errors(form)|trim) is not empty %}
{% set childErrors = [] %}

{% for child in form %}
    {% if child is defined and child.vars is defined and child.vars.errors|length > 0 %}
        {% set labelTxt = (child.vars.label is not empty) ? child.vars.label : (child.vars.name|capitalize) %}
        {% set childErrors = childErrors|merge([{
            id: child.vars.id,
            label: labelTxt,
            errors: child.vars.errors
        }]) %}
    {% endif %}
{% endfor %}

{% if hasFormErrors or childErrors is not empty %}
    {% include '_partials/form-errors.html.twig' with { form: form, childErrors: childErrors } %}
{% endif %}

<div class="max-w-2xl space-y-4 w-full">

    <div class="max-w-56">
        {{ form_row(form.albumNumber) }}
    </div>
    <div>
        {{ form_label(form.phone, 'Numer telefonu*') }}

        <div class="flex space-x-3 items-stretch">
            <div class="w-56">
                {{ form_widget(form.phone.country, {
                    attr: {
                        'aria-describedby': form.phone.vars.id ~ '_help'
                    }
                }) }}
            </div>

            <div class="flex-1">
                {{ form_widget(form.phone.number, {
                    attr: {
                        inputmode: 'tel',
                        autocomplete: 'tel',
                        placeholder: '123 456 789',
                        'aria-describedby': form.phone.vars.id ~ '_help',
                        'aria-invalid': form.phone.vars.errors|length ? 'true' : 'false'
                    }
                }) }}
            </div>
        </div>

        {{ form_errors(form.phone) }}
        {{ form_errors(form.phone.country) }}
        {{ form_errors(form.phone.number) }}
    </div>

    <div class="space-y-4">
        {{ form_row(form.studyMode) }}
        {{ form_row(form.year) }}
        {{ form_row(form.semester) }}
        {{ form_row(form.faculty) }}
    </div>

    {{ form_row(form.equipmentItems, {
        row_attr: { class: 'space-y-2' },
        label_attr: { class: 'font-medium text-zinc-800 dark:text-zinc-200' },
        attr: { class: 'space-y-2' }
    }) }}

    <div class="hidden">
        {{ form_widget(form.equipment) }}
    </div>

    <div id="equipment-types" class="mt-2 space-y-3"></div>
    <p class="text-sm mt-2 text-zinc-600 dark:text-white">
        {% trans %}Okres wypożyczenia określają daty rozpoczęcia i zakończenia.
            Maksymalny czas wypożyczenia sprzętu wynosi <strong>6 miesięcy</strong>{% endtrans %}
    </p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {{ form_row(form.rentStart, {
            label: 'Data rozpoczęcia*',
        }) }}
        {{ form_row(form.rentEnd, {
            label: 'Data zakończenia*',
        }) }}
    </div>

    {{ form_row(form.description, {
        attr: {
            class: 'w-full',
            rows: 5,
            maxlength: 150,
            placeholder: 'Opisz, dlaczego potrzebujesz wypożyczyć sprzęt'
        },
    }) }}

    <div class="text-sm text-gray-500 mt-1">
        <span id="desc-count">0</span> / 1000
    </div>

</div>

{{ form_rest(form) }}

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const textarea = document.getElementById('{{ form.description.vars.id }}');
        const counter = document.getElementById('desc-count');

        if (!textarea || !counter) return;

        const update = () => {
            counter.textContent = textarea.value.length;
        };

        update();
        textarea.addEventListener('input', update);
    });
</script>

<script>
    // Fokus na podsumowaniu błędów po załadowaniu
    document.addEventListener('DOMContentLoaded', function () {
        const summary = document.getElementById('form_error_summary');
        if (summary) summary.focus();
    });

    // Skok do pola po kliknięciu w pozycję z podsumowania błędów
    document.addEventListener('click', function (e) {
        const t = e.target.closest('[data-focus-target]');
        if (!t) return;
        const id = t.getAttribute('data-focus-target');
        const field = document.getElementById(id);
        if (field) field.focus();
    });
</script>
<script>
    (function () {
        const whenReady = (cb) => {
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', cb);
                document.addEventListener('turbo:load', cb); // jeśli używasz Turbo
            } else {
                cb();
            }
        };

        whenReady(function () {
            const API_TYPES_URL = '{{ path("api_inventory_types_for_item") }}';
            const typesHost = document.getElementById('equipment-types');
            if (!typesHost) {
                console.warn('[equip] brak #equipment-types');
                return;
            }

            const equipSelect = document.getElementById('{{ form.equipment.vars.id }}'); // ukryty <select multiple>
            const API_RESERVE = '{{ path("api_inventory_reserve_first_free") }}';
            const API_CANCEL = '{{ path("api_inventory_cancel_reservation") }}';

            const reservedByItemAndType = new Map();
            const reservedInventoryIds = new Set();

            function addInventoryToSelect(inventoryId) {
                if (!equipSelect) return;
                let opt = equipSelect.querySelector(`option[value="${ inventoryId }"]`);
                if (!opt) {
                    opt = new Option(inventoryId, inventoryId, true, true); // selected od razu
                    equipSelect.add(opt);
                } else {
                    opt.selected = true;
                }
            }

            function removeInventoryFromSelect(inventoryId) {
                if (!equipSelect) return;
                const opt = equipSelect.querySelector(`option[value="${ inventoryId }"]`);
                if (opt) equipSelect.remove(opt.index);
            }

            async function reserveFirstFree(typeId) {
                const res = await fetch(API_RESERVE, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: JSON.stringify({ typeId })
                });
                if (!res.ok) throw new Error('reserve HTTP ' + res.status);
                return res.json(); // { inventoryId, availableLeft }
            }

            async function cancelReservation(inventoryId, { beacon = false } = {}) {
                try {
                    const payload = JSON.stringify({ inventoryId });

                    if (beacon && navigator.sendBeacon) {
                        navigator.sendBeacon(API_CANCEL, payload);
                    } else {
                        await fetch(API_CANCEL, {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'X-Requested-With': 'XMLHttpRequest'
                            },
                            body: payload
                        });
                    }
                } catch (e) {
                } finally {
                    reservedInventoryIds.delete(inventoryId);
                }
            }

            const namePrefix = '{{ form.equipmentItems.vars.full_name|e('js') }}';
            const checkboxes = document.querySelectorAll(
                `input[type="checkbox"][name^="${ namePrefix }"]`
            );
            if (!checkboxes.length) {
                console.warn('[equip] nie znaleziono checkboxów');
                return;
            }

            function ensureTypesContainer(itemId, itemLabel) {
                let box = document.getElementById('types-for-' + itemId);
                if (box) return box;
                box = document.createElement('div');
                box.id = 'types-for-' + itemId;
                box.className = 'ml-6 pl-4 border-l border-zinc-200 dark:border-zinc-700 mt-2';
                box.innerHTML =
                    '<fieldset class="space-y-2">' +
                    '<legend class="text-sm font-medium text-zinc-700 dark:text-zinc-300">' +
                    (itemLabel || '{{ "Typ"|trans|e("js") }}') +
                    '</legend>' +
                    '<div class="types-list space-y-2"></div>' +
                    '</fieldset>';
                typesHost.appendChild(box);
                return box;
            }

            function removeTypesContainer(itemId) {
                const box = document.getElementById('types-for-' + itemId);
                if (box) box.remove();
            }

            async function loadAndRenderTypes(itemId, itemLabel) {
                const box = ensureTypesContainer(itemId, itemLabel);
                const list = box.querySelector('.types-list');
                list.textContent = '{{ "Ładowanie..."|trans }}';
                try {
                    const res = await fetch(
                        `${ API_TYPES_URL }?itemId=${ encodeURIComponent(itemId) }`,
                        { headers: { 'X-Requested-With': 'XMLHttpRequest' } }
                    );
                    if (!res.ok) throw new Error(`HTTP ${ res.status }`);
                    const data = await res.json();

                    if (!Array.isArray(data) || data.length === 0) {
                        list.textContent = '{{ "Brak zdefiniowanych typów."|trans }}';
                        return;
                    }

                    list.innerHTML = '';
                    data.forEach(t => {
                        const id = `subtype_${ itemId }_${ t.id }`;
                        const label = document.createElement('label');
                        label.className =
                            'flex items-center gap-2 text-sm text-zinc-800 dark:text-zinc-200';

                        const input = document.createElement('input');
                        input.type = 'checkbox';
                        input.name = `subtype_${ itemId }_${ t.id }`;
                        input.value = t.id;
                        input.id = id;
                        input.className =
                            'rounded border-zinc-300 text-indigo-600 focus:ring-indigo-500';

                        const span = document.createElement('span');
                        span.textContent =
                            t.type +
                            (t.available !== undefined
                                ? ` ({{ "Liczba dostępnych sztuk: "|trans }} ${ t.available } )`
                                : '');

                        label.appendChild(input);
                        label.appendChild(span);
                        list.appendChild(label);

                        input.addEventListener('change', async () => {
                            const key = itemId + '::' + t.id;

                            if (input.checked) {
                                // nowa rezerwacja dla danego typu
                                try {
                                    const payload = await reserveFirstFree(t.id);
                                    const invId = payload.inventoryId;
                                    reservedByItemAndType.set(key, invId);
                                    reservedInventoryIds.add(invId);
                                    addInventoryToSelect(invId);
                                } catch (e) {
                                    console.error('[equip] reserve error', e);
                                    input.checked = false;
                                }
                            } else {
                                const prevInv = reservedByItemAndType.get(key);
                                if (prevInv) {
                                    await cancelReservation(prevInv);
                                    removeInventoryFromSelect(prevInv);
                                    reservedByItemAndType.delete(key);
                                }
                            }
                        });
                    });
                } catch (e) {
                    console.error('[equip] fetch error', e);
                    list.textContent = '{{ "Nie udało się załadować typów."|trans }}';
                }
            }

            function onToggle(e) {
                const cb = e.currentTarget;
                const itemId = cb.value;
                const labelEl = cb.closest('label') || cb.parentElement;
                const itemLabel = labelEl ? labelEl.textContent.trim() : '';

                if (cb.checked) {
                    loadAndRenderTypes(itemId, itemLabel + ' — {{ "typ"|trans }}');
                } else {
                    // anuluj WSZYSTKIE rezerwacje powiązane z tym itemem
                    const prefix = itemId + '::';
                    const keysToDelete = [];
                    for (const [key, invId] of reservedByItemAndType.entries()) {
                        if (key.startsWith(prefix)) {
                            cancelReservation(invId);
                            removeInventoryFromSelect(invId);
                            keysToDelete.push(key);
                        }
                    }
                    keysToDelete.forEach(k => reservedByItemAndType.delete(k));

                    removeTypesContainer(itemId);
                }
            }

            checkboxes.forEach(cb => cb.addEventListener('change', onToggle));

            checkboxes.forEach(cb => {
                if (cb.checked) {
                    const labelEl = cb.closest('label') || cb.parentElement;
                    const itemLabel = labelEl ? labelEl.textContent.trim() : '';
                    loadAndRenderTypes(cb.value, itemLabel + ' — {{ "typ"|trans }}');
                }
            });

            // anulowanie rezerwacji sprzętu
            let formSubmitted = false;
            const formEl = equipSelect ? equipSelect.closest('form') : null;

            if (formEl) {
                formEl.addEventListener('submit', () => {
                    formSubmitted = true;
                });
            }

            window.addEventListener('beforeunload', () => {
                if (formSubmitted) return; // wniosek wysłany – zostawiamy rezerwacje

                // anuluje wszystkie rezerwacje zrobione w tej sesji
                const ids = Array.from(reservedInventoryIds);
                ids.forEach(invId => {
                    cancelReservation(invId, { beacon: true });
                    removeInventoryFromSelect(invId);
                });
                reservedByItemAndType.clear();
                reservedInventoryIds.clear();
            });

            console.log('[equip] checkboxy:', checkboxes.length, checkboxes);
        });
    })();
</script>



