<p id="form_help" class="sr-only">
    {% trans %}Formularz zgłoszeniowy. Pola wymagane oznaczono gwiazdką. Użyj klawisza Tab, aby przechodzić między polami.{% endtrans %}
</p>

{# Podsumowanie błędów #}
{% set hasFormErrors = (form_errors(form)|trim) is not empty %}
{% set childErrors = [] %}

{% for child in form %}
    {% if child is defined and child.vars is defined and child.vars.errors|length > 0 %}
        {% set labelTxt = (child.vars.label is not empty) ? child.vars.label : (child.vars.name|capitalize) %}
        {% set childErrors = childErrors|merge([{
            id: child.vars.id,
            label: labelTxt,
            errors: child.vars.errors
        }]) %}
    {% endif %}
{% endfor %}

{% if hasFormErrors or childErrors is not empty %}
    {% include '_partials/form-errors.html.twig' with { form: form, childErrors: childErrors } %}
{% endif %}

<div class="max-w-2xl space-y-4 w-full">

    {# Dane podstawowe w siatce #}
    <div class="p-5 space-y-6"
    >
        <div class="max-w-56">
            {{ form_row(form.albumNumber) }}
        </div>

        <div>
            {{ form_label(form.phone, 'Numer telefonu*') }}

            <div class="flex space-x-3 items-stretch">
                <div class="w-56">
                    {{ form_widget(form.phone.country, {
                        attr: {
                            'aria-describedby': form.phone.vars.id ~ '_help'
                        }
                    }) }}
                </div>

                <div class="flex-1">
                    {{ form_widget(form.phone.number, {
                        attr: {
                            inputmode: 'tel',
                            autocomplete: 'tel',
                            placeholder: '123 456 789',
                            'aria-describedby': form.phone.vars.id ~ '_help',
                            'aria-invalid': form.phone.vars.errors|length ? 'true' : 'false'
                        }
                    }) }}
                </div>
            </div>

            {{ form_errors(form.phone) }}
            {{ form_errors(form.phone.country) }}
            {{ form_errors(form.phone.number) }}
        </div>

        {{ form_row(form.studyMode) }}
        {{ form_row(form.year) }}
        {{ form_row(form.semester) }}
        {{ form_row(form.faculty) }}
    </div>

    {# Adaptacje / opis #}
    {% if form.adaptations is defined %}
        {{ form_row(form.adaptations, { attr: { class: 'w-full' }, label_attr: { class: 'font-medium text-zinc-800 dark:text-zinc-200' } }) }}
    {% endif %}
    {% if form.adaptation_another is defined %}
        {{ form_row(form.adaptation_another, { attr: { class: 'w-full' }, label_attr: { class: 'font-medium text-zinc-800 dark:text-zinc-200' } }) }}
    {% endif %}
    {% if form.description is defined %}
        {{ form_row(form.description, { attr: { class: 'w-full' }, label_attr: { class: 'font-medium text-zinc-800 dark:text-zinc-200' } }) }}
    {% endif %}

    {# ==== Wgrywanie plików – jeden wspólny blok, bez dzielenia na sekcje ==== #}
    {% set uploadCollections = [] %}
    {% if form.file is defined %}{% set uploadCollections = uploadCollections|merge(['file']) %}{% endif %}
    <section class="rounded-2xl bg-white dark:bg-zinc-900 shadow-sm p-5"
        role="region" aria-labelledby="files_heading" aria-describedby="files_hint">
        <header class="mb-3">
            <h2 id="files_heading" class="text-base font-semibold text-zinc-900 dark:text-white">
                {% trans %}Załączniki{% endtrans %}
            </h2>
            <p id="files_hint" class="text-sm text-zinc-600 dark:text-zinc-300">
                {% trans %}Możesz dodać do 3 plików. Dołącz wymagane oświadczenia{% endtrans %}.
            </p>
        </header>

        {# 1) ZAŁĄCZNIKI – DECYZJA #}
        <div class="mb-6">
            <h3 class="text-sm font-semibold text-zinc-900 dark:text-zinc-100 mb-2">
                {% trans %}Orzeczenie o niepełnosprawności lub inny dokument potwierdzający trudności{% endtrans %}
            </h3>

            <div id="decision_file_wrapper"
                class="space-y-3"
                role="group"
                aria-describedby="files_hint decision_files_counter"
                data-prototype="{{ form_widget(form.statement.vars.prototype)|e('html_attr') }}"
                data-max="3"
                data-entry-class="file-field"
                data-index="{{ form.statement|length }}">
                {% for fileField in form.statement %}
                    <div class="file-field rounded-xl bg-zinc-50 dark:bg-zinc-800 p-1">
                        {{ form_row(fileField, { row_attr: { class: 'w-full' }, attr: { class: 'w-full' } }) }}
                        <button type="button"
                            class="mt-2 inline-flex items-center gap-2 rounded-xl px-3 py-1.5 text-sm font-medium text-red-700 hover:bg-red-50 dark:text-red-300 dark:hover:bg-red-900/20 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-600 remove-file-btn"
                            aria-label="Usuń plik">
                            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                <path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                            </svg>
                            {% trans %}Usuń{% endtrans %}
                        </button>
                    </div>
                {% endfor %}
            </div>

            <div class="mt-3 flex items-center justify-between gap-3">
                <button type="button"
                    class="add_file_btn inline-flex items-center gap-2 rounded-xl bg-blue-600 px-4 py-2 text-sm text-white font-medium shadow-sm hover:bg-blue-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600 disabled:opacity-50 disabled:cursor-not-allowed"
                    data-wrapper-id="decision_file_wrapper">
                    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                    </svg>
                    {% trans %}Dodaj plik{% endtrans %}
                </button>
                <span class="sr-only files_live" aria-live="polite"></span>
            </div>

            <p id="decision_files_counter" class="mt-2 text-xs text-zinc-500 dark:text-zinc-400">
                {% trans %}Liczba dodanych plików{% endtrans %}:
                <span data-counter-for="decision_file_wrapper">0</span>/3
            </p>
        </div>

        {# 2) ZAŁĄCZNIKI – PLAN ZAJĘĆ #}
        <div>
            <h3 class="text-sm font-semibold text-zinc-900 dark:text-zinc-100 mb-2">
                {% trans %}Harmonogram zajęć z zaznaczeniem, na których zajęciach asystent jest niezbędny{% endtrans %}
            </h3>

            <div id="schedule_file_wrapper"
                class="space-y-3"
                role="group"
                aria-describedby="files_hint schedule_files_counter"
                data-prototype="{{ form_widget(form.schedule.vars.prototype)|e('html_attr') }}"
                data-max="3"
                data-entry-class="file-field"
                data-index="{{ form.schedule|length }}">
                {% for fileField in form.schedule %}
                    <div class="file-field rounded-xl bg-zinc-50 dark:bg-zinc-800 p-1">
                        {{ form_row(fileField, { row_attr: { class: 'w-full' }, attr: { class: 'w-full' } }) }}
                        <button type="button"
                            class="mt-2 inline-flex items-center gap-2 rounded-xl px-3 py-1.5 text-sm font-medium text-red-700 hover:bg-red-50 dark:text-red-300 dark:hover:bg-red-900/20 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-600 remove-file-btn"
                            aria-label="Usuń plik">
                            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                <path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                            </svg>
                            {% trans %}Usuń{% endtrans %}
                        </button>
                    </div>
                {% endfor %}
            </div>

            <div class="mt-3 flex items-center justify-between gap-3">
                <button type="button"
                    class="add_file_btn inline-flex items-center gap-2 rounded-xl bg-blue-600 px-4 py-2 text-sm text-white font-medium shadow-sm hover:bg-blue-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600 disabled:opacity-50 disabled:cursor-not-allowed"
                    data-wrapper-id="schedule_file_wrapper">
                    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                    </svg>
                    {% trans %}Dodaj plik{% endtrans %}
                </button>
                <span class="sr-only files_live" aria-live="polite"></span>
            </div>

            <p id="schedule_files_counter" class="mt-2 text-xs text-zinc-500 dark:text-zinc-400">
                {% trans %}Liczba dodanych plików{% endtrans %}:
                <span data-counter-for="schedule_file_wrapper">0</span>/3
            </p>
        </div>
    </section>

    {{ form_row(form.justification) }}
    {% if form.request is defined %}
        {{ form_row(form.request) }}
    {% endif %}
    <br>
    {% if form.agreements is defined %}
        {{ form_row(form.agreements) }}
    {% endif %}
    {% if form.statute is defined %}
        {{ form_row(form.statute) }}
    {% endif %}

    {{ form_rest(form) }}
</div>

<script>
    (function () {
        function byId(id) {
            return document.getElementById(id);
        }

        document.addEventListener('DOMContentLoaded', function () {
            const summary = byId('form_error_summary');
            if (summary) summary.focus();
        });

        function updateCounter(wrapper) {
            const entryClass = wrapper.dataset.entryClass || 'file-field';
            const count = wrapper.querySelectorAll('.' + entryClass).length;
            const counter = document.querySelector('[data-counter-for="' + wrapper.id + '"]');
            if (counter) counter.textContent = String(count);
            return count;
        }

        function wireFilesFor(wrapper, addBtn, liveRegion) {
            if (!wrapper || !addBtn) return;

            const max = parseInt(wrapper.dataset.max || '3', 10);
            const entryClass = wrapper.dataset.entryClass || 'file-field';
            let index = parseInt(wrapper.dataset.index || '0', 10);

            function announce(msg) {
                if (liveRegion) {
                    liveRegion.textContent = '';
                    requestAnimationFrame(() => liveRegion.textContent = msg);
                }
            }

            function setBtnState() {
                const count = updateCounter(wrapper);
                const disabled = count >= max;
                addBtn.disabled = disabled;
                addBtn.setAttribute('aria-disabled', String(disabled));
            }

            function attachRemove(container) {
                const btn = container.querySelector('.remove-file-btn');
                if (!btn) return;
                btn.addEventListener('click', function () {
                    container.remove();
                    setBtnState();
                    announce('{% trans %}Usunięto plik. Łącznie{% endtrans %}: ' + updateCounter(wrapper) + '.');
                    addBtn.focus();
                });
            }

            // istniejące
            wrapper.querySelectorAll('.' + entryClass).forEach(attachRemove);

            addBtn.addEventListener('click', function () {
                const count = updateCounter(wrapper);
                if (count >= max) return;

                const prototype = wrapper.dataset.prototype;
                const html = prototype.replace(/__name__/g, index);
                index++;
                wrapper.dataset.index = String(index);

                const container = document.createElement('div');
                container.className = entryClass + ' rounded-xl bg-zinc-50 dark:bg-zinc-800 p-4 shadow-sm';
                container.innerHTML = html;

                // przycisk Usuń (jeśli nie dodał go już prototyp)
                if (!container.querySelector('.remove-file-btn')) {
                    const removeBtn = document.createElement('button');
                    removeBtn.type = 'button';
                    removeBtn.className = 'mt-2 inline-flex items-center gap-2 rounded-xl px-3 py-1.5 text-sm font-medium text-red-700 hover:bg-red-50 dark:text-red-300 dark:hover:bg-red-900/20 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-600 remove-file-btn';
                    removeBtn.setAttribute('aria-label', 'Usuń plik');
                    removeBtn.innerHTML = '<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg> {% trans %}Usuń{% endtrans %}';
                    removeBtn.addEventListener('click', function () {
                        container.remove();
                        setBtnState();
                        announce('{% trans %}Usunięto plik. Łącznie{% endtrans %}: ' + updateCounter(wrapper) + '.');
                        addBtn.focus();
                    });
                    container.appendChild(removeBtn);
                } else {
                    attachRemove(container);
                }

                wrapper.appendChild(container);

                setBtnState();
                announce('{% trans %}Dodano plik. Łącznie{% endtrans %}: ' + updateCounter(wrapper) + '.');

                const firstInput = container.querySelector('input, select, textarea, button');
                if (firstInput) firstInput.focus();
            });

            setBtnState();
        }

        document.addEventListener('DOMContentLoaded', function () {
            // dla każdej sekcji z przyciskiem .add_file_btn
            document.querySelectorAll('.add_file_btn').forEach(addBtn => {
                const wrapperId = addBtn.getAttribute('data-wrapper-id');
                const wrapper = byId(wrapperId);
                const live = addBtn.closest('div').querySelector('.files_live');
                if (wrapper) {
                    wireFilesFor(wrapper, addBtn, live);
                }
            });
        });

        // Klik w link z podsumowania błędów przenosi fokus do pola
        document.addEventListener('click', function (e) {
            const target = e.target.closest('[data-focus-target]');
            if (!target) return;
            const id = target.getAttribute('data-focus-target');
            const field = document.getElementById(id);
            if (field) field.focus();
        });
    })();
</script>
