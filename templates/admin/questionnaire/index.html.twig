{% extends 'admin/_layouts/after-login.html.twig' %}
{% form_theme form 'admin/_layouts/form-tailwind.html.twig' %}

{% block stylesheets %}{{ encore_entry_link_tags('admin_default') }}{% endblock %}
{% block javascripts %}{{ encore_entry_script_tags('admin_default') }}{% endblock %}
{% block title %}{% trans %}Ankieta oceny aplikacji{% endtrans %}{% endblock %}
{% block body %}

    <div class="mb-12">
        {{ website_path([
            { label: 'Ustawienia'|trans, route: 'admin_settings' },
            { label: 'Ankieta oceny aplikacji'|trans },
        ]) }}
    </div>

    <div class="mb-7 text-2xl font-bold">Pytania zamknięte</div>
    <div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-3">
        {% for field, avg in averages %}
            {% set label = attribute(form, field).vars.label ?? field %}
            {% set safeAvg = avg ?? 0 %}
            {% set percent = (safeAvg / 5 * 100)|round %}

            <div class="rounded-2xl bg-white dark:bg-zinc-800 p-4 shadow-sm hover:shadow-md transition">
                <div class="flex items-start justify-between gap-3">
                    <div class="text-sm font-semibold text-black dark:text-white leading-snug">
                        {{ label }}
                    </div>

                    <span class="shrink-0 rounded-full bg-slate-100 px-2.5 py-1 text-sm font-semibold text-slate-900 tabular-nums">
          {{ safeAvg|number_format(2, '.', ' ') }} / 5
        </span>
                </div>

                <div class="mt-3 h-2 w-full overflow-hidden rounded-full bg-slate-100">
                    <div class="h-full rounded-full bg-blue-600 dark:bg-yellow-400"
                        style="width: {{ percent }}%"></div>
                </div>

                <div class="mt-2 flex items-center justify-between text-xs text-black dark:text-white">
                    <span class="tabular-nums">{{ percent }}%</span>
                </div>
            </div>
        {% endfor %}
    </div>

    <div class="mt-7 text-2xl font-bold">Pytania otwarte</div>

    {# ====== PRZYCISKI ====== #}
    <div class="mt-10 max-w-250 rounded-2xl p-4 shadow-sm">
        <div class="grid grid-cols-1 gap-3">
            <button type="button" data-modal-target="modal-q6" data-modal-toggle="modal-q6" class="bg-white dark:bg-zinc-800 rounded-lg px-4 py-3 hover:bg-zinc-200 dark:hover:bg-zinc-900">
                {{ form.q6.vars.label }}
            </button>
            <button type="button" data-modal-target="modal-q8" data-modal-toggle="modal-q8"
                class="bg-white dark:bg-zinc-800 rounded-lg px-4 py-3 hover:bg-zinc-200 dark:hover:bg-zinc-900">
                {{ form.q8.vars.label }}
            </button>
            <button type="button" data-modal-target="modal-q12" data-modal-toggle="modal-q12" class="bg-white dark:bg-zinc-800 rounded-lg px-4 py-3 hover:bg-zinc-200 dark:hover:bg-zinc-900">
                {{ form.q12.vars.label }}
            </button>
            <button type="button" data-modal-target="modal-q13" data-modal-toggle="modal-q13" class="bg-white dark:bg-zinc-800 rounded-lg px-4 py-3 hover:bg-zinc-200 dark:hover:bg-zinc-900">
                {{ form.q13.vars.label }}
            </button>
            <button type="button" data-modal-target="modal-q14" data-modal-toggle="modal-q14" class="bg-white dark:bg-zinc-800 rounded-lg px-4 py-3 hover:bg-zinc-200 dark:hover:bg-zinc-900">
                {{ form.q14.vars.label }}
            </button>
        </div>
    </div>

    {# ====== MODAL: Q6 ====== #}
    <div id="modal-q6" tabindex="-1" aria-hidden="true"
        class="hidden overflow-y-auto overflow-x-hidden fixed top-0 right-0 left-0 z-50 justify-center items-center w-full md:inset-0 h-[calc(100%-1rem)] max-h-full">
        <div class="relative p-4 w-full max-w-2xl max-h-full">
            <div class="relative bg-white rounded-lg shadow dark:bg-zinc-700">
                <div class="flex items-center justify-between p-4 md:p-5 border-b dark:border-zinc-600">
                    <h3 class="text-xl font-semibold text-zinc-900 dark:text-white">{{ form.q6.vars.label }}</h3>
                    <button type="button" data-modal-hide="modal-q6"
                        class="text-zinc-400 hover:bg-zinc-200 hover:text-zinc-900 rounded-lg text-sm w-8 h-8 inline-flex justify-center items-center dark:hover:bg-zinc-600 dark:hover:text-white">
                        ✕
                    </button>
                </div>

                <div class="p-4 md:p-5 space-y-3 max-h-[70vh] overflow-auto">
                    {% set has = false %}
                    {% for q in questionnaire %}
                        {% set val = (q.q6 ?? '')|trim %}
                        {% if val != '' %}
                            {% set has = true %}
                            <div class="rounded-lg border border-zinc-200 p-3 dark:border-zinc-600">
                                <div class="text-xs text-zinc-500 dark:text-zinc-300 mb-1">Rekord #{{ loop.index }}</div>
                                <div class="whitespace-pre-wrap text-zinc-800 dark:text-zinc-100">{{ val }}</div>
                            </div>
                        {% endif %}
                    {% endfor %}
                    {% if not has %}
                        <p class="text-zinc-500 dark:text-zinc-300">Brak odpowiedzi.</p>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

