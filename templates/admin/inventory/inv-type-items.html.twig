{% extends 'admin/_layouts/after-login.html.twig' %}

{% block stylesheets %}{{ encore_entry_link_tags('admin_default') }}{% endblock %}
{% block javascripts %}{{ encore_entry_script_tags('admin_default') }}{% endblock %}
{% block title %}{% trans %}Sprzęt{% endtrans %}{% endblock %}
{% block body %}
    <header class="mb-6 flex items-start justify-between gap-4">
        {{ website_path([
            { label: 'Ustawienia'|trans, route: 'admin_settings' },
            { label: 'Inwentaryzacja sprzętu'|trans, route: 'admin_inventory' },
            { label: 'Lista typów sprzętu'|trans, route: 'admin_inventory_equipment', route_params: { item: item.id } },
            { label: 'Sprzęt do wypożyczenia'|trans }
        ]) }}
    </header>

    <div class="mb-6">
        <label for="settings-search" class="sr-only">{% trans %}Szukaj sprzętu{% endtrans %}</label>
        <input id="settings-search" type="search" placeholder="{% trans %}Szukaj sprzętu…{% endtrans %}"
            class="w-full rounded-xl border border-zinc-300 bg-white px-4 py-2.5 text-sm text-zinc-900 placeholder-zinc-400
                  focus:ring-4 focus:ring-zinc-100 focus:outline-none
                  dark:border-zinc-700 dark:bg-zinc-800 dark:text-white dark:placeholder-zinc-500 dark:focus:ring-zinc-800"
            oninput="filterCards(this.value)">
    </div>

    <section class="bg-white p-4 rounded-lg dark:bg-zinc-900">
        <h1 class="text-xl font-semibold text-zinc-900 dark:text-white sm:text-2xl md:text-3xl">
            {% trans %}Lista sprzętu dla{% endtrans %} {{ item.value }} - {{ type.type }}
        </h1>

        <div class="mt-4 flex flex-col sm:flex-row sm:items-start gap-4">
            <a class="{{ buttonPrimary() }} {{ focusPrimaryWithPadding() }}" href="{{ url('admin_create_inv_type_item', { item: item.id, inventoryTypeId: type.id }) }}">
                {% trans %}Dodaj sprzęt{% endtrans %}
            </a>

            <a class="{{ buttonSecondary() }} {{ focusPrimaryWithPadding() }}" href="{{ url('admin_inv_excel_export', { inventoryTypeId: type.id }) }}">
                {% trans %}Eksport Excel{% endtrans %}
            </a>
        </div>

        {# Pusta lista #}
        {% if inventories is empty %}
            <div class="mt-10 rounded-lg border border-dashed border-zinc-300 p-8 text-center dark:border-zinc-700">
                <p class="text-zinc-600 dark:text-zinc-300">
                    {% trans %}Brak pozycji w inwentarzu{% endtrans %}
                </p>
            </div>
        {% else %}

            {# 1) Zgrupuj po statusie #}
            {% set grouped = {} %}
            {% for inv in inventories %}
                {% set key = inv.status is not empty ? inv.status : 'Nieznany' %}
                {% set grouped = grouped|merge({
                    (key): (grouped[key]|default([]))|merge([inv])
                }) %}
            {% endfor %}

            {# Ustal kolejność sekcji statusów: Wolny -> Zarezerwowany -> Wypożyczony -> Nieznany #}
            {% set order = ['Wolny','Zarezerwowany','Wypożyczony','Nieznany'] %}
            {#            {% set keys = (grouped|keys)|sort((a,b) => (order|index(a)|default(999)) <=> (order|index(b)|default(999))) %} #}

            {% for status in grouped|keys|sort %}
                <div class="mt-8">
                    <div class="flex items-center gap-3">
                        <div class="h-px flex-1 bg-zinc-200 dark:bg-zinc-700"></div>
                        <div class="shrink-0 rounded-full bg-zinc-100 px-3 py-1 text-xs font-medium text-zinc-700 dark:bg-zinc-800 dark:text-zinc-200">
                            {{ status }}
                        </div>
                        <div class="h-px flex-1 bg-zinc-200 dark:bg-zinc-700"></div>
                    </div>

                    <div class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
                        {% for inv in grouped[status] %}
                            {# Kolor odznaki statusu #}
                            {% set chipClasses =
                                status == 'Dostępny'
                                ? 'bg-green-500 text-white dark:bg-green-500 dark:text-white'
                                : (status == 'Zarezerwowany'
                                ? 'bg-amber-500 text-white dark:bg-amber-500 dark:text-white'
                                : (status == 'Wypożyczony'
                                ? 'bg-sky-600 text-white dark:bg-sky-600 dark:text-white'
                                : 'bg-zinc-500 text-white dark:bg-zinc-500 dark:text-white')) %}

                            {% set title = inv.serialNumber %}

                            {# prawy element nagłówka – badge statusu #}
                            {% set header_right_html %}
                                <span class="inline-flex items-center rounded-full px-2.5 py-1 text-xs font-medium {{ chipClasses }}">
        {{ status }}
    </span>
                            {% endset %}

                            {# środek karty #}
                            {% set body_html %}
                                {% if inv.status is same as('Wypożyczony') %}
                                    <dl class="space-y-2 text-sm">
                                        {% if inv.student %}
                                            <div class="flex items-center justify-between">
                                                Wypożyczony przez:
                                                <dt class="text-zinc-500 dark:text-zinc-400">
                                                    {{ inv.student.firstName }} {{ inv.student.lastName }}
                                                </dt>
                                            </div>
                                        {% endif %}
                                    </dl>

                                    <dl class="space-y-2 text-sm mt-2">
                                        {% if inv.student %}
                                            <div class="flex items-center justify-between">
                                                Termin wypożyczenia:
                                                <dt class="text-zinc-500 dark:text-zinc-400">
                                                    {{ inv.rentStart|date('d.m.Y') }} - {{ inv.rentEnd|date('d.m.Y') }}
                                                </dt>
                                            </div>
                                        {% endif %}
                                    </dl>
                                {% endif %}

                                <dl class="space-y-2 text-sm mt-2">
                                    {% if inv.description %}
                                        <div class="flex items-center justify-between">
                                            Opis:
                                            <dt class="text-zinc-500 dark:text-zinc-400">
                                                {{ inv.description }}
                                            </dt>
                                        </div>
                                    {% endif %}
                                </dl>
                            {% endset %}

                            {# akcje w stopce karty #}
                            {% set actions_html %}
                                <div class="mt-4 flex items-center justify-between">
                                    <div class="flex items-center space-x-1.5">
                                        {% if inv.status is same as('Wypożyczony') %}
                                            <a href="{{ path('admin_return_inv_item', { inventoryId: inv.id }) }}">
                                                <button
                                                    type="button"
                                                    class="cursor-pointer inline-flex items-center gap-2 rounded-2xl border border-blue-200/60 bg-blue-50 px-3 py-2 text-sm font-semibold text-blue-700 shadow-sm transition hover:bg-blue-100 hover:border-blue-300 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-400 focus-visible:ring-offset-2 dark:bg-blue-900/20 dark:text-blue-200 dark:border-blue-900/40 dark:hover:bg-blue-900/30 dark:focus-visible:ring-blue-500"
                                                    aria-label="{% trans %}Dodaj zwrot{% endtrans %}"
                                                >
                                                    <span>{% trans %}Dodaj zwrot{% endtrans %}</span>
                                                </button>
                                            </a>
                                        {% endif %}

                                        <a
                                            class="{{ buttonPrimary() }} {{ focusPrimaryWithPadding() }}"
                                            href="{{path('admin_update_inv_item', { item: item.id, inventoryId: type.id, inventory: inv.id }) }}"
                                        >
                                            {% trans %}Edytuj{% endtrans %}
                                        </a>

                                        {# unikalne ID formularza i modala #}
                                        {% set formId  = 'delete-inv-form-' ~ inv.id %}
                                        {% set modalId = 'deleteInvModal-' ~ inv.id %}

                                        <form
                                            id="{{ formId }}"
                                            method="post"
                                            action="{{ path('admin_delete_inv', { item: item.id, inventoryType: type.id, inventory: inv.id }) }}"
                                            class="ml-1"
                                        >
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ inv.id) }}">

                                            <button
                                                type="button"
                                                data-modal-target="{{ modalId }}"
                                                data-modal-toggle="{{ modalId }}"
                                                class="{{ buttonDelete() }}"
                                            >
                                                {{ 'Usuń'|trans }}
                                            </button>
                                        </form>

                                        {% include 'admin/_components/confirm-modal.html.twig' with {
                                            modalId: modalId,
                                            formId: formId,
                                            title: 'Usuwanie pozycji'|trans,
                                            message: 'Na pewno chcesz usunąć sprzęt o nr seryjnym: <br><strong>'|trans ~ inv.serialNumber ~ '</strong>?',
                                            warningText: 'Operacja jest nieodwracalna.'|trans,
                                            confirmLabel: 'Usuń'|trans,
                                            cancelLabel: 'Anuluj'|trans
                                        } %}

                                    </div>
                                </div>
                            {% endset %}

                            {{ inventory_card(
                                title,
                                body_html,
                                actions_html,
                                { header_right_html: header_right_html }
                            ) }}

                        {% endfor %}
                    </div>
                </div>
            {% endfor %}
        {% endif %}
    </section>

    {% include '_paginator/paginator.html.twig' with { pagination: pagination } %}

    <script>
        function filterCards(q = '') {
            q = (q || '').trim().toLowerCase();
            const cards = document.querySelectorAll('[data-card]');
            cards.forEach(c => {
                const text = (c.innerText || '').toLowerCase();
                c.style.display = text.includes(q) ? '' : 'none';
            });
        }
    </script>
{% endblock %}
