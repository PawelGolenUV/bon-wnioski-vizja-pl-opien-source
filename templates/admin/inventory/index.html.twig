{% extends 'admin/_layouts/after-login.html.twig' %}

{% block stylesheets %}{{ encore_entry_link_tags('admin_default') }}{% endblock %}
{% block javascripts %}{{ encore_entry_script_tags('admin_default') }}{% endblock %}
{% block title %}{% trans %}Inwentaryzacja{% endtrans %}{% endblock %}
{% block body %}
    {{ website_path([
        { label: 'Ustawienia'|trans, route: 'admin_settings' },
        { label: 'Inwentaryzacja sprzętu'|trans },
    ]) }}

    <header class="mb-6 flex items-start justify-between gap-4">
        <div>
            <h1 class="text-2xl md:text-3xl font-bold text-zinc-900 dark:text-white">{% trans %}Inwentaryzacja sprzętu{% endtrans %}</h1>
            <p class="mt-1 text-sm text-zinc-600 dark:text-zinc-300">{% trans %}Zarządzaj dostępnym sprzętem{% endtrans %}</p>
        </div>
    </header>

    {# Szybkie wyszukiwanie #}
    <div class="mb-6">
        <label
            for="inventory-search"
            class="mb-2 block text-sm font-medium text-zinc-900 dark:text-white">
            {% trans %}Szukaj sprzętu{% endtrans %}
        </label>
        <input id="inventory-search" type="search" placeholder="{% trans %}Szukaj sprzętu…{% endtrans %}"
            class="w-full rounded-xl border border-zinc-600 bg-white px-4 py-2.5 text-sm text-zinc-900 placeholder-zinc-400
                   dark:border-zinc-700 dark:bg-zinc-800 dark:text-white dark:placeholder-zinc-500 {{ focusPrimary() }}"
            oninput="filterCards(this.value)">
    </div>

    <section class="bg-white p-4 rounded-lg dark:bg-zinc-900">
        <h1 class="text-xl font-semibold text-zinc-900 dark:text-white sm:text-2xl md:text-3xl">
            {% trans %}Lista sprzętu{% endtrans %}
        </h1>

        {# Pobierz rekordy z QueryBuildera przekazanego w 'inventories' #}
        {% set items = inventories.getQuery().getResult() %}

        {% if items is empty %}
            <div class="mt-10 rounded-lg border border-dashed border-zinc-300 p-8 text-center dark:border-zinc-700">
                <p class="text-zinc-600 dark:text-zinc-300">
                    {% trans %}Brak pozycji w inwentarzu{% endtrans %}
                </p>
            </div>
        {% else %}
            {# Prosta siatka kart: każda karta = pozycja słownika (Item) dla enumu SPRZET #}
            <div id="inventory-grid" class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
                {% for item in items %}

                    {% set title = item.value ?? '—' %}

                    {% set body_html %}
                        {% if item.description is defined and item.description %}
                            <p class="text-sm text-zinc-700 dark:text-zinc-200 line-clamp-3">
                                {{ item.description }}
                            </p>
                        {% endif %}
                    {% endset %}

                    {% set actions_html %}
                        <div class="mt-4 flex items-center gap-1.5 flex-wrap">
                            <a class="{{ buttonPrimary() }} {{ focusPrimaryWithPadding() }}" href="{{ url('admin_inventory_equipment', { item: item.id }) }}">
                                {% trans %}Pokaż typ{% endtrans %}
                            </a>
                            <a
                                class="{{ buttonSecondary() }} {{ focusPrimaryWithPadding() }}"
                                href="{{path('admin_update_dictionary_item', { dictionaryItemId: item.id }) }}"
                            >
                                {% trans %}Edytuj słownik{% endtrans %}
                            </a>
                        </div>
                    {% endset %}

                    {{ inventory_card(
                        title,
                        body_html,
                        actions_html,
                        { is_active: item.isActive is defined ? item.isActive : null }
                    ) }}

                {% endfor %}
            </div>
        {% endif %}
    </section>

    {% include '_paginator/paginator.html.twig' with { pagination: pagination } %}

    <script>
        // Proste filtrowanie kart po widocznym tekście
        function filterCards(q = '') {
            q = (q || '').trim().toLowerCase();
            const cards = document.querySelectorAll('[data-card]');
            cards.forEach(c => {
                const text = (c.innerText || '').toLowerCase();
                c.style.display = text.includes(q) ? '' : 'none';
            });
        }
    </script>

{% endblock %}
